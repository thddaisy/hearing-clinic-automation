        "responses": {
          "values": [
            {
              "role": "system",
              "content": "You are a medical document parser for a hearing aid clinic. \nExtract structured data from consultation chart text and return ONLY valid JSON with no markdown, no explanation, no code blocks."
            },
            {
              "content": "=Extract the following fields from this hearing aid consultation chart and return ONLY a JSON object with no markdown, no explanation, no code blocks.\n------------------------------------------------------------------------------\nIMPORTANT RULES:\n- Date format in the document is DD-MM-YYYY. Convert to YYYY-MM-DD format. For example, 01-06-2026 becomes 2026-06-01.\n- If a field value is \"-\" or empty, return null for that field.\n- Return all fields even if null.\n------------------------------------------------------------------------------\n{\n  \"chart_no\": \"patient chart number (e.g. P1-001)\",\n  \"patient_name\": \"full patient name\",\n  \"consult_date\": \"date in YYYY-MM-DD format\",\n  \"doctor_name\": \"doctor full name without Dr. prefix\",\n  \"audiologist_name\": \"audiologist full name\",\n  \"ear_side\": \"Left / Right / Both or null\",\n  \"demo_model\": \"hearing aid model name or null\",\n  \"record_type\": \"one of: New Consultation / Fitting Completed / Repair Completed\",\n  \"hospital_name\": \"clinic name at bottom of document\",\n  \"consult_note\": \"full consultation note text in the body of the document\"\n}\n------------------------------------------------------------------------------\nChart text:\n{{ $json.text }}\n"
            }
          ]
        },
        "simplify": false,
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.3,
      "position": [
        -432,
        256
      ],
      "id": "a396b1d3-c3e3-4df9-adfa-88d62f7589a2",
      "name": "Extract Data",
      "credentials": {
        "openAiApi": {
          "id": "dweDSVlnit6vlN5h",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const raw = item.json.output[0].content[0].text;\n  const parsed = JSON.parse(raw);\n  \n  const hospitalMap = {\n    'Christchurch ENT Clinic': 'H-001',\n    'Selwyn Hearing Centre': 'H-002',\n    'Canterbury Audiology Associates': 'H-003'\n  };\n  \n  parsed.hospital_id = hospitalMap[parsed.hospital_name] || null;\n  \n  return { json: parsed };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        256
      ],
      "id": "54bfe6a4-fbb9-4800-8b24-e4980f02565c",
      "name": "Parse & Map"
    },
