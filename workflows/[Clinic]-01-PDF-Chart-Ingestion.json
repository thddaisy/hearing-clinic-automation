                  {
                    "leftValue": "={{ $json.record_type }}",
                    "rightValue": "New Consultation",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "id": "77b1ff6f-5b60-47d2-9a09-cc5cbcd2b9cd"
